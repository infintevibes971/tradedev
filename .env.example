# TradeDev Environment Configuration
# Copy to .env and fill in your values

# ── LLM Providers (at least one required for AI-powered trading) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Model overrides (optional — sensible defaults built in)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-2.0-flash

# AI Mode: "single" (primary + fallback), "consensus" (2 providers agree), "disabled"
AI_MODE=single
AI_PRIMARY_PROVIDER=claude
AI_FALLBACK_CHAIN=openai,gemini

# Database
DATABASE_URL=sqlite:///./tradedev.db

# Security - Auto-generated on first run if empty
ENCRYPTION_KEY=

# Optional - Production caching
REDIS_URL=

# Logging
LOG_LEVEL=INFO

# Exchange API Keys are stored encrypted in the database,
# NOT in this file. Use the UI Key Vault to manage them.
