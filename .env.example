# TradeDev Environment Configuration
# Copy to .env and fill in your values

# LLM - Required for agent decision-making
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=sqlite:///./tradedev.db

# Security - Auto-generated on first run if empty
ENCRYPTION_KEY=

# Optional - Production caching
REDIS_URL=

# Logging
LOG_LEVEL=INFO

# Exchange API Keys are stored encrypted in the database,
# NOT in this file. Use the UI Key Vault to manage them.
